# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Site URL — used as the redirectTo base for password reset emails.
# Must match a URL in your Supabase "Redirect URLs" allowlist.
# The production value is baked into next.config.ts as a fallback; set this
# locally if you want reset links to land on a dev server instead.
NEXT_PUBLIC_SITE_URL=https://floform.fit

# Sentry (optional — errors are silently skipped if missing)
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@o0.ingest.sentry.io/0

# PostHog (optional — analytics are silently skipped if missing)
NEXT_PUBLIC_POSTHOG_KEY=phc_your_key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
